{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@crearFamilia/*": ["./src/components/crearFamilia/*"],
      "@general/*": ["./src/components/general/*"],
      "@index/*": ["./src/components/index/*"],
      "@tabla/*": ["./src/components/tabla/*"],
      "@assets/*": ["./src/assets/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@styles/*": ["./src/styles/*"],
      "@api/*": ["./src/pages/api/*"],


    }
  }
}