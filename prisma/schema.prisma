generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model users {
  id       Int    @id @default(autoincrement()) 
  name     String    @db.VarChar(200)
  collections collection[]
}

model product {
  id          Int     @id @default(autoincrement())
  name        String? @db.VarChar(200)
  short_name  String  @unique(map: "short_name") @db.VarChar(50)
  description String? @db.Text
  RRP         Decimal @db.Decimal(10, 2)
  collections collectionProducts[]

}

model collectionProducts {
  productID Int
  collectionID Int
  product product @relation(fields: [productID], references: [id])
  collections collection @relation(fields: [collectionID], references: [id])

  @@id([productID, collectionID])
}

model collection {
  id    Int     @id @default(autoincrement())
  name   String  @db.VarChar(100)
  userID Int 
  usuario users @relation(fields: [userID], references: [id])
  products collectionProducts[]
}
