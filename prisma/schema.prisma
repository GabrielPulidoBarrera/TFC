generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model family {
  cod      String    @id @db.VarChar(6)
  name     String    @db.VarChar(200)
  products product[]
}

model product {
  cod         String  @id @db.VarChar(12)
  name        String? @db.VarChar(200)
  short_name  String  @unique(map: "short_name") @db.VarChar(50)
  description String? @db.Text
  RRP         Decimal @db.Decimal(10, 2)
  family      String  @db.VarChar(6)
  familyRel   family  @relation(fields: [family], references: [cod], map: "product_ibfk_1")
  stocks      stock[]

  @@index([family], map: "family")
}

model store {
  cod    Int     @id @default(autoincrement())
  name   String  @db.VarChar(100)
  tlf    String? @db.VarChar(13)
  stocks stock[]
}

model stock {
  product    String  @db.VarChar(12)
  store      Int
  units      Int
  productRel product @relation(fields: [product], references: [cod], map: "stock_ibfk_1")
  storeRel   store   @relation(fields: [store], references: [cod], map: "stock_ibfk_2")

  @@id([product, store])
  @@index([store], map: "stock_ibfk_2")
}
