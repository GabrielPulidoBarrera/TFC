generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"

}

model users {
  id       Int    @id @default(autoincrement()) 
  name     String    @db.VarChar(200)
  password     String    @db.Char(64)
  email     String    @db.VarChar(200) @unique
  enabled   Boolean   @default(false)
  collections collection[]
  products product[]
}

model product {
  id          Int     @id @default(autoincrement())
  name  String @db.VarChar(100)
  columns String @db.VarChar(1000)
  visibility String @db.VarChar(20)
  userID Int
  usuario users @relation(fields: [userID], references: [id])
  collections collectionProducts[]

}

model collectionProducts {
  productID Int 
  collectionID Int
  product product @relation(fields: [productID], references: [id], onDelete: Cascade)
  collections collection @relation(fields: [collectionID], references: [id], onDelete: Cascade) 
  @@id([productID, collectionID])
}

model collection {
  id    Int     @id @default(autoincrement())
  name   String  @db.VarChar(100)
  userID Int 
  columns   String  @db.VarChar(1000)
  visibility String @db.VarChar(20)
  usuario users @relation(fields: [userID], references: [id])
  products collectionProducts[]
}
