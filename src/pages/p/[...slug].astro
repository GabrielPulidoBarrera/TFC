---
const { name, id } = Astro.props;
import Layout2 from '@layouts/Layout2.astro';
import Tabla from '@tabla/Tabla.astro';
import { POST } from "@api/readProductsAll";

export async function getStaticPaths() {
let listaColecciones = [];

const response = await POST();
let resultado = await response.json();
console.log
resultado.data.map((iteracion: any) =>{
	listaColecciones.push({
		params: {slug: iteracion.name+'-'+iteracion.id},
		props: {name: iteracion.name, id: iteracion.id}});
	
	
})
return listaColecciones
}

console.log(id);


