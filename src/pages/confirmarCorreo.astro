---
import Layout from "@layouts/Layout.astro";
import { crearDialog } from "@libs/dialog/crearDialog";
const id = Astro.url.searchParams.get("id");
const url = new URL('/api/validateUser', Astro.url);


      const responseCorreo = await fetch(url, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          id: Number(id),
        }),
      });
      console.info(responseCorreo)
      if (responseCorreo.ok){
        crearDialog("El registro a funcionado. Por favor, inicie sesion para acceder a la pagina")
        window.location.href = "/login";
      }

