---
import Layout from "@layouts/Layout.astro";
//Esta pagina es la que accedes cuando haces click en el correo que te llega para validar tu correo.
const id = Astro.url.searchParams.get("id");
const url = new URL("/api/validateUser", Astro.url);

const responseCorreo = await fetch(url, {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
  },
  body: JSON.stringify({
    id: Number(id),
  }),
});
---

<Layout titulo="Confirmar correo">
  {
    responseCorreo.ok && (
      <p>
        El registro ha funcionado. Por favor, inicie sesion para acceder a la
        pagina
      </p>
    )
  }
  {!responseCorreo.ok && <p>El registo ha fallado</p>}
</Layout>
