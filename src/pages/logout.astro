---
import Layout from "@layouts/Layout.astro";
---
<!--Como tal no hay interfaz aqui, te conectas, te borra la cookie y te redirecciona a la pagina de login. -->

<Layout titulo="Logout"/>

<script>
	try {
		const response = await fetch("/api/deleteCookie", { method: "POST" });
		if (response.ok) window.location.href = "/login";
	} catch (error) {
		console.log(error);
	}
</script>
