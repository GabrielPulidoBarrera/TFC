---
import "../styles/global.css";


---
<div class="container p-2 mx-auto sm:p-4 dark:text-gray-800">
	<div class="flex justify-between">
	<h2 class="mb-4 text-2xl font-semibold leading-tight" id="collectionTitle"> TITULO ASTRO</h2>
			<button class="self-center px-8 py-3 font-semibold rounded dark:bg-violet-600 dark:text-gray-50 cursor-pointer" id="editar">Edit</button>
			<button class="self-center px-8 py-3 font-semibold rounded dark:bg-violet-600 dark:text-gray-50 cursor-pointer hidden" id="terminar">Finish</button>

	</div>
	<div class="overflow-x-auto">
		<table class="min-w-full text-xs *:text-center">
			<colgroup>

			</colgroup>
			<thead class="dark:bg-gray-300">
				<tr class=" *:p-3">
				</tr>
			</thead>
			<tbody class="*:border-b *:border-opacity-20 *:dark:border-gray-300 *:dark:bg-gray-50 *:p-3">
				<tr class="">
				</tr>

			</tbody>
		</table>
	</div>
</div>


<script>
	    let tbody = document.querySelector<HTMLElement>('tbody');
	let editar = document.querySelector<HTMLElement>('#editar')
	let terminar = document.querySelector<HTMLElement>('#terminar')
	let titulo = document.querySelector<HTMLElement>('#collectionTitle')
	let thead = document.querySelector<HTMLElement>('thead')
	let id;

	async function readProduct() {
	if (tbody==null){
		return
	}
		if (tbody.lastElementChild==null){
		return
	}
	if (titulo==null){
		return
	}
	if (thead==null){
		return
	}
	if (thead.firstElementChild==null){
		return
	}


    const response = await fetch("/api/readCollections", {
      method: "POST",
    });
    let resultado = await response.json();
    console.log(resultado.data);
	let correcto = resultado.data[0];
	let columnas = JSON.parse(correcto.columns);
	titulo.textContent=correcto.name
	console.log(columnas)
	for (let i of columnas){
		let th = document.createElement('th')
		th.textContent = i;
		thead?.firstElementChild.append(th);
		tbody.firstElementChild?.append(document.createElement('td'));
	}
	id = correcto.id;





  }

  function activarEditar(){

	if (editar==null){
		return
	}
	if (terminar==null){
		return
	}
	if (tbody==null){
		return
	}


	editar.style.display="none"
	terminar.style.display="block"

	let tr = document.createElement('tr');
	let numeroTD = tbody.lastElementChild?.childElementCount

		if (numeroTD==null){
		return
	}
	for (let i = 0; i < numeroTD; i++){
		let td = document.createElement('td')
		td.textContent="A"
		tr.append(td);
	}
	tbody?.append(tr)


	let todosTD = document.querySelectorAll('td')
	let todosTH = document.querySelectorAll('th')

	for (let iterable of todosTD){
	  iterable.setAttribute("contenteditable", "true");
	}
	for (let iterable of todosTH){
	  iterable.setAttribute("contenteditable", "true");
	}
	titulo?.setAttribute("contenteditable", "true");
	console.log(id)
}

  readProduct()
  editar?.addEventListener("click", activarEditar);

</script>