---
import "@styles/global.css";
import Boton from '@general/Boton.astro';
import { obtenerCookie } from "../../libs/auth/controlCookies";

        let cookie = await obtenerCookie(Astro.cookies?.get("sesion"));


---
<section class="p-6 dark:text-gray-900">
	<form novalidate="" action="" class="container flex flex-col mx-auto space-y-12">
		<fieldset class="grid grid-cols-4 gap-6 p-6 rounded-md shadow-sm">
			<div class="space-y-2 col-span-full lg:col-span-1">
				<p class="font-medium">Crear colecciones</p>
				<p class="text-xs">El nombre de la coleccion sera el nombre visible en el selector de colecciones y en los resultados de busqueda.</p>
				<p class="text-xs">La visibilidad define si la coleccion puede ser encontrado en la busqueda o no.</p>
				<p class="text-xs">Las columnas definiran los atributos que se mostraran en la tabla.</p>
                <p class="text-xs">Todos estos valores pueden ser modificados en cualquier momento.</p>
                
			</div>
			<div class="grid grid-cols-6 gap-4 col-span-full lg:col-span-3">
				<div class="col-span-full sm:col-span-3">
					<label for="name" class="text-sm">Name</label>
					<input id="name" type="text" placeholder="Name" class="w-full rounded-md focus:ring focus:ring-opacity-75">
				</div>
				<div class="col-span-full sm:col-span-3">
					<label for="visibility" class="text-sm">Visibility</label>
                    <select id="visibility" class="w-full rounded-md focus:ring focus:ring-opacity-75">
        
                        <option>Publico</option>
                        <option>Privado</option>
                        <option>Oculto</option>
                    </select>
				</div>
		</fieldset>


        <div>
          <fieldset>
            <legend>Columnas de la tabla</legend>
            <span id="selectorColumnas">
              <input type="text" class="columna" id="columna1"> <label for="columna1">Columna 1</label>
              <input type="text" class="columna" id="columna2"> <label for="columna2">Columna 2</label>
            </span>
          </fieldset>
            <button type="button" id="nuevaColumna">Añadir mas columnas</button>

        </div>

				</div>
	</form>
</section>

<div id="crearColeccion" class="flex items-center justify-center cursor-pointer">
    <Boton text="añadir"></Boton>
</div>

<script define:vars={{ cookie }}>
	let boton = document.querySelector('#crearColeccion');
  let nuevaColumna = document.querySelector('#nuevaColumna');
  let selectorColumnas = document.querySelector('#selectorColumnas');
  nuevaColumna?.addEventListener("click", newColumn);
  let contador = 3;

  function newColumn(){
    let input = document.createElement('input');
    input.id = "columna"+contador;
    input.classList.add('columna')
    let label = document.createElement('label');
    label.textContent = "Columna "+contador;
    label.htmlFor = "columna"+contador;
    contador++
    selectorColumnas?.append(input);
    selectorColumnas?.append(label);

  }

	 async function newCollection() {
    let collectionName =(document.querySelector("#name")).value;
    let userID = Number(cookie);
    let collectionVisibility =(document.querySelector("#visibility")).value;
    let columnasRaw = selectorColumnas?.querySelectorAll('.columna')
    let columnas = [];
    for (let iterable of columnasRaw){
      columnas.push(iterable.value);
    }
    columnas = JSON.stringify(columnas);
    console.log(columnas)

    const response = await fetch("/api/newCollection", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        name: collectionName,
        userID: userID,
		visibility: collectionVisibility,
    columns: columnas
      }),
    });
    console.log(response);
    const result = await response.json();
    console.log("Response data:", result);
    alert("Response: " + result.message);
  }

  boton?.addEventListener("click", newCollection);
</script>

