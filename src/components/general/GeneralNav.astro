---
import "@styles/global.css";
import { obtenerCookie } from "@libs/auth/controlCookies";
let cookie = obtenerCookie(Astro.cookies?.get('sesion'));
---
<header class="p-4 bg-gray-100 text-gray-800">
	<div class="container flex justify-between h-16 mx-auto">
		<a rel="noopener noreferrer" href="/" aria-label="Back to homepage" class="lg:flex items-center p-2 hidden">
			<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16" class="w-8 h-8 text-violet-600">
				<path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z"/>
			</svg>
		</a>
		<ul class="items-stretch space-x-3 flex">
			{cookie &&
			<li class="flex">
				<a rel="noopener noreferrer" href="/seleccion" class="flex items-center px-4 -mb-1 border-b-2 hover:bg-gray-200">Seleccionar coleccion</a>
			</li>
			}
			<li class="flex">
				<a rel="noopener noreferrer" href="/buscar" class="flex items-center px-4 -mb-1 border-b-2 hover:bg-gray-200">Buscar</a>
			</li>
			{cookie &&
			<li class="flex">
				<a rel="noopener noreferrer" href="/crearProducto" class="flex items-center px-4 -mb-1 border-b-2 hover:bg-gray-200">Añadir producto</a>
			</li>
			}
		</ul>
		<div class="items-center shrink-0 flex">
			{!cookie &&
				<a href="/login"><button class="self-center px-8 py-3 cursor-pointer rounded hover:bg-gray-200">Iniciar sesión</button></a>
				<a href="/registro"><button class="self-center px-8 py-3 font-semibold rounded cursor-pointer bg-violet-600 text-gray-50 hover:bg-violet-700">Registrarse</button></a>
			}
			{cookie &&
				<a href="/logout"><button class="hidden lg:block self-center px-8 py-3 cursor-pointer rounded hover:bg-gray-200">Cerrar sesión</button></a>
				
			}
		</div>

	</div>
</header>