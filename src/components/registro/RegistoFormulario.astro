---
import "@styles/global.css";
---

<section class="p-6 dark:text-gray-900">
  <form
    novalidate=""
    action=""
    class="container flex flex-col mx-auto space-y-12"
  >
    <fieldset class="grid grid-cols-4 gap-6 p-6 rounded-md shadow-sm">
      <div>
        <label for="correo" class="text-sm">Coreo</label>
        <input
          id="correo"
          type="email"
          placeholder="correo"
          class="w-full rounded-md focus:ring focus:ring-opacity-75"
        />
      </div>
      <div>
        <label for="nombre" class="text-sm">nombre</label>
        <input
          id="nombre"
          type="text"
          placeholder="nombre"
          class="w-full rounded-md focus:ring focus:ring-opacity-75"
        />
      </div>
      <div>
        <label for="password" class="text-sm">Contraseña</label>
        <input
          id="password"
          type="password"
          placeholder="contraseña"
          class="w-full rounded-md focus:ring focus:ring-opacity-75"
        />
      </div>
      <div>
        <p>Reglas para el registro:</p>
        <p>El usuario no debe de contener caracteres especiales y debe de tener al menos 8 caracteres</p>
        <p>La contraseña debe de tener al menos una mayuscula, una minuscula, un numero, y 8 caracteres de longitud.</p>
      </div>
    </fieldset>
    <button
      type="button"
      id="crearUsuario"
      class="self-center px-8 py-3 rounded font-semibold dark:bg-violet-600 dark:text-gray-50"
    >
      <span id="textoBoton">Crear usuario</span>

      <div class="cargar hidden">
        <svg
          aria-hidden="true"
          class="w-8 h-8 text-neutral-tertiary animate-spin fill-black"
          viewBox="0 0 100 101"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z"
            fill="currentColor"></path>
          <path
            d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z"
            fill="currentFill"></path>
        </svg>
        <span class="sr-only">Loading...</span>
      </div>
    </button>
  </form>
</section>

<script>
  import { getSHA256Hash } from "boring-webcrypto-sha256";
  import { crearDialog } from "@libs/dialog/crearDialog";

  let cargar = document.querySelector(".cargar") as HTMLElement;
  let textoBoton = document.querySelector("#textoBoton") as HTMLElement;

  let botonUsuario = document.querySelector("#crearUsuario");
  botonUsuario?.addEventListener("click", nuevoUsuario);

  async function nuevoUsuario() {
    let error = "";
    let valido = true;

    if (document.querySelector("#correo") == null) {
      valido = false;
    }
    if (document.querySelector("#nombre") == null) {
      valido = false;
    }
    if (document.querySelector("#password") == null) {
      valido = false;
    }

    //Muestro el spinner
    textoBoton.style.display = "none";
    cargar.style.display = "block";

    let username = (document.querySelector("#nombre") as HTMLInputElement)
      .value;
    let emailUsuario = (document.querySelector("#correo") as HTMLInputElement)
      .value;
    let password = (document.querySelector("#password") as HTMLInputElement)
      .value;

    //He copiado y pegado este regex de google.
    let emailRegex =
      /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
    if (emailRegex.test(emailUsuario) == false) {
      error+="\n Tu email es invalido";
      valido = false;
    }
    //Este regex se asegura de que no tenga carateres especiales.
    let usuarioRegex = /^[A-Za-z0-9]*$/;
    if (usuarioRegex.test(username) == false) {
      error+="\n Tu usuario no puede contener caracteres especiales";
      valido = false;
    }

    if (username.length<8){
      error+="\n Tu usuario es demasiado corto"
      valido = false;
    }

    let mayusculaRegex = /[A-Z]/;
    let minusculaRegex = /[a-z]/;
    let numeroRegex = /[0-9]/;

    if (password.length < 8) {
      error+="\n Tu contraseña es muy corta";
      valido = false;
    }

    if (mayusculaRegex.test(password) == false) {
      error+="\n Tu contraseña debe de contener al menos una mayuscula.";
      valido = false;
    }

    if (minusculaRegex.test(password) == false) {
      error+="\n Tu contraseña debe de contener al menos una minuscula.";
      valido = false;
    }
    if (numeroRegex.test(password) == false) {
      error+="\n Tu contraseña debe de contener al menos un numero.";
      valido = false;
    }

    if (valido == true) {
      password = await getSHA256Hash(password);
      const response = await fetch("../api/newUser", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          name: username,
          email: emailUsuario,
          password: password,
        }),
      });
      console.log(response);
      if (response.ok) {
        const responseData = await response.json();
        let id = responseData.data.id;

        //Envio el email de confirmacion usuario.

        const responseCorreo = await fetch("../api/sendEmail", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            email: emailUsuario,
            id: id,
          }),
        });
        console.info(responseCorreo);
      }
      cargar.style.display = "none";
      textoBoton.style.display = "block";
      crearDialog("El registro ha funcionado. Revisa tu correo electronico para verificar el email.")
    } else {
      crearDialog(error)
      cargar.style.display = "none";
      textoBoton.style.display = "block";
      return
    }
  }
</script>
